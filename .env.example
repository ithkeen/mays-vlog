# UCloud 星图 ModelVerse API Key（用于调用 kling-v3 视频生成接口）
MODELVERSE_API_KEY=your-modelverse-api-key-here

# UCloud UFile 公钥
UFILE_PUBLIC_KEY=your-ufile-public-key-here

# UCloud UFile 私钥
UFILE_PRIVATE_KEY=your-ufile-private-key-here

# UFile 存储空间名（需在 UCloud 控制台手动创建）
UFILE_BUCKET=your-bucket-name

# UFile bucket 所在 region（如 cn-bj / cn-sh2 / hk 等）
UFILE_REGION=cn-bj
